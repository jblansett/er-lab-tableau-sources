        <caption>
          <formatted-text>
            <run><![CDATA[- Target analytes that were not detected are reported as the "<" symbol followed by the reporting limit
]]></run>
            <run fontcolor='#000000'>- Results are screened against ATSDR Minimal Risk Levels (MRLs), health-based inhalation screening values developed by the Agency for Toxic Substances and Disease Registry.</run>
            <run>Æ&#10;</run>
            <run auto-url='true' fontcolor='#000000' hyperlink='tabdoc:load-url url=&amp;quot;https://wwwn.cdc.gov/TSP/MRLS/mrlsListing.aspx&amp;quot;'>https://wwwn.cdc.gov/TSP/MRLS/mrlsListing.aspx</run>
            <run>Æ&#10;</run>
            <run fontcolor='#000000'>- NE = Not Established</run>
          </formatted-text>
        </caption>
      </layout-options>
      <repository-location id='TO-15ResultsScreened' path='/workbooks/PROJ-069775AnalyticalAirReporting' revision='' />
