      <layout-options export-legend-location='bottom' export-margin-bottom='0.25' export-margin-left='0.25' export-margin-right='0.25' export-margin-top='0.25'>
        <title>
          <formatted-text>
            <run fontname='Arial'><![CDATA[<[federated.1gw41mf0rtc9dw1glafc4167k6u4].[none:Project Name:nk]>]]></run>
            <run>Æ&#10;</run>
            <run fontname='Arial Black' fontsize='12'><![CDATA[<[Parameters].[Parameter 2]> | <[federated.1gw41mf0rtc9dw1glafc4167k6u4].[none:Project City:nk]>, <[federated.1gw41mf0rtc9dw1glafc4167k6u4].[none:Project State:nk]>]]></run>
            <run>Æ&#10;</run>
            <run fontname='Arial Black' fontsize='12'>&lt;Sheet Name&gt;</run>
          </formatted-text>
        </title>
        <caption>
          <formatted-text>
            <run><![CDATA[- Target analytes that were not detected are reported as the "<" symbol followed by the reporting limit
]]></run>
            <run fontcolor='#000000'>- Results are screened against ATSDR Minimal Risk Levels (MRLs), health-based inhalation screening values developed by the Agency for Toxic Substances and Disease Registry.</run>
            <run>Æ&#10;</run>
            <run auto-url='true' fontcolor='#000000' hyperlink='tabdoc:load-url url=&amp;quot;https://wwwn.cdc.gov/TSP/MRLS/mrlsListing.aspx&amp;quot;'>https://wwwn.cdc.gov/TSP/MRLS/mrlsListing.aspx</run>
            <run>Æ&#10;</run>
            <run fontcolor='#000000'>- NE = Not Established</run>
          </formatted-text>
        </caption>
      </layout-options>
      <repository-location id='TO-15ResultsScreened' path='/workbooks/PROJ-069775AnalyticalAirReporting' revision='' />
      <table>
        <view>
          <datasources>
            <datasource caption='Minican Sampling Results SQL with MRLs' name='federated.1gw41mf0rtc9dw1glafc4167k6u4' />
            <datasource name='Parameters' />
          </datasources>
          <datasource-dependencies datasource='Parameters'>
            <column caption='Tier 1 Screening' datatype='string' name='[Parameter 1]' param-domain-type='list' role='measure' type='nominal' value='&quot;ATSDR Chronic MRL&quot;'>
              <calculation class='tableau' formula='&quot;ATSDR Chronic MRL&quot;' />
            </column>
            <column caption='Enter Project Number' datatype='string' name='[Parameter 2]' param-domain-type='any' role='measure' type='nominal' value='&quot;PROJ-069775&quot;'>
              <calculation class='tableau' formula='&quot;PROJ-069775&quot;' />
            </column>
            <column caption='Tier 3 Screening' datatype='string' name='[Tier 1 Screening (copy) (copy)_1660983859054993417]' param-domain-type='list' role='measure' type='nominal' value='&quot;ATSDR Acute MRL&quot;'>
              <calculation class='tableau' formula='&quot;ATSDR Acute MRL&quot;' />
            </column>
            <column caption='Tier 2 Screening' datatype='string' name='[Tier 1 Screening (copy)_1660983859054985224]' param-domain-type='list' role='measure' type='nominal' value='&quot;ATSDR Intermediate MRL&quot;'>
              <calculation class='tableau' formula='&quot;ATSDR Intermediate MRL&quot;' />
            </column>
          </datasource-dependencies>
          <datasource-dependencies datasource='federated.1gw41mf0rtc9dw1glafc4167k6u4'>
            <column aggregation='Sum' caption='Acute MRL (ppbv)' datatype='real' name='[ATSDR MRL - Inhalation, Acute (ppbv) (copy)_1660983859048562689]' role='dimension' type='ordinal'>
              <calculation class='tableau' formula='[ATSDR MRL - Inhalation, Acute (ppbv)]' />
              <aliases>
                <alias key='%null%' value='NE' />
              </aliases>
            </column>
            <column datatype='string' name='[ATSDR MRL - Inhalation, Acute (ppbv) String]' role='dimension' type='nominal' />
            <column aggregation='Sum' datatype='real' name='[ATSDR MRL - Inhalation, Acute (ppbv)]' role='dimension' type='ordinal' />
            <column aggregation='Sum' caption='Chronic MRL (ppbv)' datatype='real' name='[ATSDR MRL - Inhalation, Chronic (ppbv) (copy)_1660983859048624130]' role='dimension' type='ordinal'>
              <calculation class='tableau' formula='/*&#13;&#10;This MRL comes from the table &#13;&#10;in the samples_cteh_com database in the public schema&#13;&#10;*/&#13;&#10;[ATSDR MRL - Inhalation, Chronic (ppbv)]' />
              <aliases>
                <alias key='%null%' value='NE' />
              </aliases>
            </column>
            <column datatype='string' name='[ATSDR MRL - Inhalation, Chronic (ppbv) String]' role='dimension' type='nominal' />
            <column aggregation='Sum' datatype='real' name='[ATSDR MRL - Inhalation, Chronic (ppbv)]' role='dimension' type='ordinal' />
            <column aggregation='Sum' caption='Intermediate MRL (ppbv)' datatype='real' name='[ATSDR MRL - Inhalation, Intermediate (ppbv) (copy)_1660983859048689667]' role='dimension' type='ordinal'>
              <calculation class='tableau' formula='[ATSDR MRL - Inhalation, Intermediate (ppbv)]' />
              <aliases>
                <alias key='%null%' value='NE' />
              </aliases>
            </column>
            <column datatype='string' name='[ATSDR MRL - Inhalation, Intermediate (ppbv) String]' role='dimension' type='nominal' />
            <column aggregation='Sum' datatype='real' name='[ATSDR MRL - Inhalation, Intermediate (ppbv)]' role='dimension' type='ordinal' />
            <column datatype='string' name='[Analyte]' role='dimension' type='nominal' />
            <column datatype='string' name='[Analytical Method]' role='dimension' type='nominal' />
            <column datatype='string' name='[CAS Number]' role='dimension' type='nominal' />
            <column caption='Detection Legend' datatype='string' name='[Calculation_1660983859049345028]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='IF [Detected?] THEN &apos;Detection&apos; ELSE &apos;Non-Detection&apos; END' />
            </column>
            <column caption='Tier 1 Screening Value' datatype='real' name='[Calculation_1660983859055177738]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='IF [Parameters].[Parameter 1] = &apos;ATSDR Acute MRL&apos; THEN [ATSDR MRL - Inhalation, Acute (ppbv) (copy)_1660983859048562689]&#13;&#10;ELSEIF [Parameters].[Parameter 1] = &apos;ATSDR Intermediate MRL&apos; THEN [ATSDR MRL - Inhalation, Intermediate (ppbv) (copy)_1660983859048689667]&#13;&#10;ELSEIF [Parameters].[Parameter 1] = &apos;ATSDR Chronic MRL&apos; THEN [ATSDR MRL - Inhalation, Chronic (ppbv) (copy)_1660983859048624130]&#13;&#10;ELSEIF [Parameters].[Parameter 1] = &apos;None&apos; THEN NULL&#13;&#10;END' />
            </column>
            <column caption='Screening Legend' datatype='string' name='[Calculation_1660983859057324046]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='IF NOT [Detected?] THEN&#13;&#10;    &quot;Non-Detection&quot;&#13;&#10;&#13;&#10;ELSEIF ISNULL([Calculation_1660983859055177738])&#13;&#10;    AND ISNULL([Tier 1 Screening Value (copy)_1660983859055460363])&#13;&#10;    AND ISNULL([Tier 2 Screening Value (copy)_1660983859055599629])&#13;&#10;THEN&#13;&#10;    &quot;Detection - No Screening Value Established&quot;&#13;&#10;&#13;&#10;ELSEIF NOT ISNULL([Calculation_1660983859055177738]) THEN&#13;&#10;    IF [Result] &gt;= [Calculation_1660983859055177738] THEN&#13;&#10;        &quot;Detection ≥ Screening Value&quot;&#13;&#10;    ELSE&#13;&#10;        &quot;Detection &lt; Screening Value&quot;&#13;&#10;    END&#13;&#10;&#13;&#10;ELSEIF NOT ISNULL([Tier 1 Screening Value (copy)_1660983859055460363]) THEN&#13;&#10;    IF [Result] &gt;= [Tier 1 Screening Value (copy)_1660983859055460363] THEN&#13;&#10;        &quot;Detection ≥ Screening Value&quot;&#13;&#10;    ELSE&#13;&#10;        &quot;Detection &lt; Screening Value&quot;&#13;&#10;    END&#13;&#10;&#13;&#10;ELSEIF NOT ISNULL([Tier 2 Screening Value (copy)_1660983859055599629]) THEN&#13;&#10;    IF [Result] &gt;= [Tier 2 Screening Value (copy)_1660983859055599629] THEN&#13;&#10;        &quot;Detection ≥ Screening Value&quot;&#13;&#10;    ELSE&#13;&#10;        &quot;Detection &lt; Screening Value&quot;&#13;&#10;    END&#13;&#10;&#13;&#10;ELSE&#13;&#10;    &quot;Detection - No Screening Value Established&quot;&#13;&#10;END' />
            </column>
            <column caption='Screening Value' datatype='string' name='[Calculation_1660983859059326991]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='IF NOT ISNULL([Calculation_1660983859055177738]) THEN&#13;&#10;    CASE [Parameters].[Parameter 1]&#13;&#10;        WHEN &quot;ATSDR Acute MRL&quot; THEN [ATSDR MRL - Inhalation, Acute (ppbv) String] + &quot; (Acute)&quot;&#13;&#10;        WHEN &quot;ATSDR Intermediate MRL&quot; THEN [ATSDR MRL - Inhalation, Intermediate (ppbv) String] + &quot; (Int)&quot;&#13;&#10;        WHEN &quot;ATSDR Chronic MRL&quot; THEN [ATSDR MRL - Inhalation, Chronic (ppbv) String] + &quot; (Chronic)&quot;&#13;&#10;    END&#13;&#10;&#13;&#10;ELSEIF NOT ISNULL([Tier 1 Screening Value (copy)_1660983859055460363]) THEN&#13;&#10;    CASE [Parameters].[Tier 1 Screening (copy)_1660983859054985224]&#13;&#10;        WHEN &quot;ATSDR Acute MRL&quot; THEN [ATSDR MRL - Inhalation, Acute (ppbv) String] + &quot; (Acute)&quot;&#13;&#10;        WHEN &quot;ATSDR Intermediate MRL&quot; THEN [ATSDR MRL - Inhalation, Intermediate (ppbv) String] + &quot; (Int)&quot;&#13;&#10;        WHEN &quot;ATSDR Chronic MRL&quot; THEN [ATSDR MRL - Inhalation, Chronic (ppbv) String] + &quot; (Chronic)&quot;&#13;&#10;    END&#13;&#10;&#13;&#10;ELSEIF NOT ISNULL([Tier 2 Screening Value (copy)_1660983859055599629]) THEN&#13;&#10;    CASE [Parameters].[Tier 1 Screening (copy) (copy)_1660983859054993417]&#13;&#10;        WHEN &quot;ATSDR Acute MRL&quot; THEN [ATSDR MRL - Inhalation, Acute (ppbv) String] + &quot; (Acute)&quot;&#13;&#10;        WHEN &quot;ATSDR Intermediate MRL&quot; THEN [ATSDR MRL - Inhalation, Intermediate (ppbv) String] + &quot; (Int)&quot;&#13;&#10;        WHEN &quot;ATSDR Chronic MRL&quot; THEN [ATSDR MRL - Inhalation, Chronic (ppbv) String] + &quot; (Chronic)&quot;&#13;&#10;    END&#13;&#10;&#13;&#10;ELSE&#13;&#10;    &quot;NE&quot;&#13;&#10;END' />
            </column>
            <column datatype='boolean' name='[Detected?]' role='dimension' type='nominal' />
            <column datatype='string' name='[Location Code]' role='dimension' type='nominal' />
            <column datatype='string' name='[Location Type]' role='dimension' type='nominal' />
