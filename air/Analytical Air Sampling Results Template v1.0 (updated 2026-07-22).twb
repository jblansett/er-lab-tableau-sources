      <column caption='Screening Value' datatype='string' name='[Calculation_1660983859082391577]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF NOT ISNULL([Calculation_1660983859082088470]) THEN&#13;&#10;    CASE [Parameters].[Parameter 1]&#13;&#10;        WHEN &quot;ATSDR Acute MRL&quot; THEN [ATSDR MRL - Inhalation, Acute (µg/m³) String] + &quot; (Acute)&quot;&#13;&#10;        WHEN &quot;ATSDR Intermediate MRL&quot; THEN [ATSDR MRL - Inhalation, Intermediate (µg/m³) String] + &quot; (Int)&quot;&#13;&#10;        WHEN &quot;ATSDR Chronic MRL&quot; THEN [ATSDR MRL - Inhalation, Chronic (µg/m³) String] + &quot; (Chronic)&quot;&#13;&#10;    END&#13;&#10;&#13;&#10;ELSEIF NOT ISNULL([Tier 1 Screening Value (copy)_1660983859082207255]) THEN&#13;&#10;    CASE [Parameters].[Tier 1 Screening (copy)_1660983859054985224]&#13;&#10;        WHEN &quot;ATSDR Acute MRL&quot; THEN [ATSDR MRL - Inhalation, Acute (µg/m³) String] + &quot; (Acute)&quot;&#13;&#10;        WHEN &quot;ATSDR Intermediate MRL&quot; THEN [ATSDR MRL - Inhalation, Intermediate (µg/m³) String] + &quot; (Int)&quot;&#13;&#10;        WHEN &quot;ATSDR Chronic MRL&quot; THEN [ATSDR MRL - Inhalation, Chronic (µg/m³) String] + &quot; (Chronic)&quot;&#13;&#10;    END&#13;&#10;&#13;&#10;ELSEIF NOT ISNULL([Tier 1 Screening Value (copy) (copy)_1660983859082211352]) THEN&#13;&#10;    CASE [Parameters].[Tier 1 Screening (copy) (copy)_1660983859054993417]&#13;&#10;        WHEN &quot;ATSDR Acute MRL&quot; THEN [ATSDR MRL - Inhalation, Acute (µg/m³) String] + &quot; (Acute)&quot;&#13;&#10;        WHEN &quot;ATSDR Intermediate MRL&quot; THEN [ATSDR MRL - Inhalation, Intermediate (µg/m³) String] + &quot; (Int)&quot;&#13;&#10;        WHEN &quot;ATSDR Chronic MRL&quot; THEN [ATSDR MRL - Inhalation, Chronic (µg/m³) String] + &quot; (Chronic)&quot;&#13;&#10;    END&#13;&#10;&#13;&#10;ELSE&#13;&#10;    &quot;NE&quot;&#13;&#10;END' />
      </column>
      <column caption='Screening Legend' datatype='string' name='[Calculation_1660983859082719258]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF NOT [Detected?] THEN&#13;&#10;    &quot;Non-Detection&quot;&#13;&#10;&#13;&#10;ELSEIF ISNULL([Calculation_1660983859082088470])&#13;&#10;    AND ISNULL([Tier 1 Screening Value (copy)_1660983859082207255])&#13;&#10;    AND ISNULL([Tier 1 Screening Value (copy) (copy)_1660983859082211352])&#13;&#10;THEN&#13;&#10;    &quot;Detection - No Screening Value Established&quot;&#13;&#10;&#13;&#10;ELSEIF NOT ISNULL([Calculation_1660983859082088470]) THEN&#13;&#10;    IF [Result] &gt;= [Calculation_1660983859082088470] THEN&#13;&#10;        &quot;Detection ≥ Screening Value&quot;&#13;&#10;    ELSE&#13;&#10;        &quot;Detection &lt; Screening Value&quot;&#13;&#10;    END&#13;&#10;&#13;&#10;ELSEIF NOT ISNULL([Tier 1 Screening Value (copy)_1660983859082207255]) THEN&#13;&#10;    IF [Result] &gt;= [Tier 1 Screening Value (copy)_1660983859082207255] THEN&#13;&#10;        &quot;Detection ≥ Screening Value&quot;&#13;&#10;    ELSE&#13;&#10;        &quot;Detection &lt; Screening Value&quot;&#13;&#10;    END&#13;&#10;&#13;&#10;ELSEIF NOT ISNULL([Tier 1 Screening Value (copy) (copy)_1660983859082211352]) THEN&#13;&#10;    IF [Result] &gt;= [Tier 1 Screening Value (copy) (copy)_1660983859082211352] THEN&#13;&#10;        &quot;Detection ≥ Screening Value&quot;&#13;&#10;    ELSE&#13;&#10;        &quot;Detection &lt; Screening Value&quot;&#13;&#10;    END&#13;&#10;&#13;&#10;ELSE&#13;&#10;    &quot;Detection - No Screening Value Established&quot;&#13;&#10;END' />
      </column>
      <column aggregation='Sum' caption='Screening Reference Line' datatype='real' name='[Calculation_1660983859091927074]' role='dimension' type='ordinal'>
        <calculation class='tableau' formula='IF NOT ISNULL([Calculation_1660983859082088470]) THEN&#13;&#10;    CASE [Parameters].[Parameter 1]&#13;&#10;        WHEN &quot;ATSDR Acute MRL&quot; THEN [ATSDR MRL - Inhalation, Acute (µg/m³)]&#13;&#10;        WHEN &quot;ATSDR Intermediate MRL&quot; THEN [ATSDR MRL - Inhalation, Intermediate (µg/m³)]&#13;&#10;        WHEN &quot;ATSDR Chronic MRL&quot; THEN [ATSDR MRL - Inhalation, Chronic (µg/m³)]&#13;&#10;    END&#13;&#10;&#13;&#10;ELSEIF NOT ISNULL([Tier 1 Screening Value (copy)_1660983859082207255]) THEN&#13;&#10;    CASE [Parameters].[Tier 1 Screening (copy)_1660983859054985224]&#13;&#10;        WHEN &quot;ATSDR Acute MRL&quot; THEN [ATSDR MRL - Inhalation, Acute (µg/m³)]&#13;&#10;        WHEN &quot;ATSDR Intermediate MRL&quot; THEN [ATSDR MRL - Inhalation, Intermediate (µg/m³)]&#13;&#10;        WHEN &quot;ATSDR Chronic MRL&quot; THEN [ATSDR MRL - Inhalation, Chronic (µg/m³)]&#13;&#10;    END&#13;&#10;&#13;&#10;ELSEIF NOT ISNULL([Tier 1 Screening Value (copy) (copy)_1660983859082211352]) THEN&#13;&#10;    CASE [Parameters].[Tier 1 Screening (copy) (copy)_1660983859054993417]&#13;&#10;        WHEN &quot;ATSDR Acute MRL&quot; THEN [ATSDR MRL - Inhalation, Acute (µg/m³)]&#13;&#10;        WHEN &quot;ATSDR Intermediate MRL&quot; THEN [ATSDR MRL - Inhalation, Intermediate (µg/m³)]&#13;&#10;        WHEN &quot;ATSDR Chronic MRL&quot; THEN [ATSDR MRL - Inhalation, Chronic (µg/m³)]&#13;&#10;    END&#13;&#10;END' />
      </column>
      <column caption='Location Geometry' datatype='spatial' name='[Calculation_1660983859093446691]' role='measure' type='nominal'>
        <calculation class='tableau' formula='MAKEPOINT([Location Latitude], [Location Longitude], 4326) &#13;&#10;&#13;&#10;//SRID 4326 = Coord System WGS1984&#13;&#10;//Best geographic coord system for point data' />
      </column>
      <column caption='Sample Geometry' datatype='spatial' name='[Calculation_1660983859093651492]' role='measure' type='nominal'>
        <calculation class='tableau' formula='MAKEPOINT([Location Latitude], [Location Longitude], 4326) &#13;&#10;&#13;&#10;//SRID 4326 = Coord System WGS1984&#13;&#10;//Best geographic coord system for point data' />
      </column>
      <column caption='Site Location' datatype='spatial' name='[Calculation_1660983859095855141]' role='measure' type='nominal'>
        <calculation class='tableau' formula='MAKEPOINT(34.01557095420967, -118.19352507591249, 4326)&#13;&#10;&#13;&#10;//SRID 4326 = Coord System WGS1984&#13;&#10;//Best geographic coord system for point data' />
      </column>
      <column caption='Detection Range' datatype='string' name='[Calculation_2221584817442816]' role='measure' type='nominal'>
        <calculation class='tableau' formula='IF [Calculation_2221584820383755] = 0 THEN&#13;&#10;    MIN([Calculation_2221584820035593])&#13;&#10;ELSEIF [Calculation_2221584820383755] = 1 THEN&#13;&#10;    MIN([Calculation_2221584819933192])&#13;&#10;ELSE&#13;&#10;    MIN([Calculation_2221584819933192]) + &apos; - &apos; + MAX([Calculation_2221584820232202])&#13;&#10;END' />
      </column>
      <column caption='_Min Detection Value' datatype='real' name='[Calculation_2221584819023877]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='{ INCLUDE [Location Code], [Analyte], [CAS Number], [Result Units] :&#13;&#10;    MIN(IF [Detected?] THEN [Result] END) }' />
      </column>
      <column caption='_Max Detection Value' datatype='real' name='[Calculation_2221584819585030]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='{ INCLUDE [Location Code], [Analyte], [CAS Number], [Result Units] :&#13;&#10;    MAX(IF [Detected?] THEN [Result] END) }' />
      </column>
      <column caption='_Min All Value' datatype='real' name='[Calculation_2221584819654663]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='{ INCLUDE [Location Code], [Analyte], [CAS Number], [Result Units] :&#13;&#10;    MIN([Result]) }' />
      </column>
      <column caption='_Min Detect Formatted' datatype='string' name='[Calculation_2221584819933192]' role='measure' type='nominal'>
        <calculation class='tableau' formula='{ INCLUDE [Location Code], [Analyte], [CAS Number], [Result Units] :&#13;&#10;    MIN(IF [Detected?] AND [Result] = [Calculation_2221584819023877]&#13;&#10;        THEN [Result Formatted] END) }' />
      </column>
      <column caption='_Min All Formatted' datatype='string' default-type='ordinal' name='[Calculation_2221584820035593]' role='measure' type='nominal'>
        <calculation class='tableau' formula='{ INCLUDE [Location Code], [Analyte], [CAS Number], [Result Units] :&#13;&#10;    MIN(IF [Result] = [Calculation_2221584819654663]&#13;&#10;        THEN [Result Formatted] END) }' />
      </column>
      <column caption='_Max Detect Formatted' datatype='string' name='[Calculation_2221584820232202]' role='measure' type='nominal'>
        <calculation class='tableau' formula='{ INCLUDE [Location Code], [Analyte], [CAS Number], [Result Units] :&#13;&#10;    MAX(IF [Detected?] AND [Result] = [Calculation_2221584819585030]&#13;&#10;        THEN [Result Formatted] END) }' />
      </column>
      <column caption='_Detection Count' datatype='integer' name='[Calculation_2221584820383755]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNTD(IF [Detected?] THEN [Sample ID] END)' />
      </column>
      <column caption='Count of Samples' datatype='integer' name='[Calculation_2221584830484494]' role='measure' type='ordinal'>
        <calculation class='tableau' formula='COUNTD([Sample ID])' />
      </column>
      <column caption='Count of Detections' datatype='integer' name='[Calculation_2221584830521359]' role='measure' type='ordinal'>
        <calculation class='tableau' formula='COUNTD(IF [Detected?] THEN [Sample ID] END)' />
      </column>
      <column caption='Project Geometry' datatype='spatial' name='[Calculation_804455509491052545]' role='measure' type='nominal'>
        <calculation class='tableau' formula='MAKEPOINT([Project Latitude], [Project Longitude], 4326)&#13;&#10;&#13;&#10;//SRID 4326 = Coord System WGS1984&#13;&#10;//Best geographic coord system for point data' />
      </column>
      <column aggregation='Avg' datatype='real' name='[Location Latitude]' role='measure' semantic-role='[Geographical].[Latitude]' type='quantitative' />
      <column aggregation='Avg' datatype='real' name='[Location Longitude]' role='measure' semantic-role='[Geographical].[Longitude]' type='quantitative' />
      <column datatype='string' name='[Project City]' role='dimension' semantic-role='[City].[Name]' type='nominal' />
      <column aggregation='Avg' datatype='real' name='[Project Latitude]' role='measure' semantic-role='[Geographical].[Latitude]' type='quantitative' />
      <column aggregation='Avg' datatype='real' name='[Project Longitude]' role='measure' semantic-role='[Geographical].[Longitude]' type='quantitative' />
      <column datatype='string' name='[Project State]' role='dimension' semantic-role='[State].[Name]' type='nominal' />
      <column aggregation='Avg' datatype='real' name='[Sample Latitude]' role='measure' semantic-role='[Geographical].[Latitude]' type='quantitative' />
      <column aggregation='Avg' datatype='real' name='[Sample Longitude]' role='measure' semantic-role='[Geographical].[Longitude]' type='quantitative' />
      <column caption='Tier 3 Screening Value' datatype='real' name='[Tier 1 Screening Value (copy) (copy)_1660983859082211352]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF [Parameters].[Tier 1 Screening (copy) (copy)_1660983859054993417] = &apos;ATSDR Acute MRL&apos; THEN [ATSDR MRL - Inhalation, Acute (µg/m³) (copy)_1660983859081338898]&#13;&#10;ELSEIF [Parameters].[Tier 1 Screening (copy) (copy)_1660983859054993417] = &apos;ATSDR Intermediate MRL&apos; THEN [ATSDR MRL - Inhalation, Intermediate (µg/m³) (copy)_1660983859081543700]&#13;&#10;ELSEIF [Parameters].[Tier 1 Screening (copy) (copy)_1660983859054993417] = &apos;ATSDR Chronic MRL&apos; THEN [ATSDR MRL - Inhalation, Chronic (µg/m³) (copy)_1660983859081486355]&#13;&#10;ELSEIF [Parameters].[Tier 1 Screening (copy) (copy)_1660983859054993417] = &apos;None&apos; THEN NULL&#13;&#10;END' />
      </column>
      <column caption='Tier 2 Screening Value' datatype='real' name='[Tier 1 Screening Value (copy)_1660983859082207255]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF [Parameters].[Tier 1 Screening (copy)_1660983859054985224] = &apos;ATSDR Acute MRL&apos; THEN [ATSDR MRL - Inhalation, Acute (µg/m³) (copy)_1660983859081338898]&#13;&#10;ELSEIF [Parameters].[Tier 1 Screening (copy)_1660983859054985224] = &apos;ATSDR Intermediate MRL&apos; THEN [ATSDR MRL - Inhalation, Intermediate (µg/m³) (copy)_1660983859081543700]&#13;&#10;ELSEIF [Parameters].[Tier 1 Screening (copy)_1660983859054985224] = &apos;ATSDR Chronic MRL&apos; THEN [ATSDR MRL - Inhalation, Chronic (µg/m³) (copy)_1660983859081486355]&#13;&#10;ELSEIF [Parameters].[Tier 1 Screening (copy)_1660983859054985224] = &apos;None&apos; THEN NULL&#13;&#10;END' />
      </column>
