            <column datatype='date' name='[Sample Date]' role='dimension' type='ordinal' />
            <column datatype='string' name='[Sample ID]' role='dimension' type='nominal' />
            <column caption='Tier 3 Screening Value' datatype='real' name='[Tier 1 Screening Value (copy) (copy)_1660983859082211352]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='IF [Parameters].[Tier 1 Screening (copy) (copy)_1660983859054993417] = &apos;ATSDR Acute MRL&apos; THEN [ATSDR MRL - Inhalation, Acute (µg/m³) (copy)_1660983859081338898]&#13;&#10;ELSEIF [Parameters].[Tier 1 Screening (copy) (copy)_1660983859054993417] = &apos;ATSDR Intermediate MRL&apos; THEN [ATSDR MRL - Inhalation, Intermediate (µg/m³) (copy)_1660983859081543700]&#13;&#10;ELSEIF [Parameters].[Tier 1 Screening (copy) (copy)_1660983859054993417] = &apos;ATSDR Chronic MRL&apos; THEN [ATSDR MRL - Inhalation, Chronic (µg/m³) (copy)_1660983859081486355]&#13;&#10;ELSEIF [Parameters].[Tier 1 Screening (copy) (copy)_1660983859054993417] = &apos;None&apos; THEN NULL&#13;&#10;END' />
            </column>
            <column caption='Tier 2 Screening Value' datatype='real' name='[Tier 1 Screening Value (copy)_1660983859082207255]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='IF [Parameters].[Tier 1 Screening (copy)_1660983859054985224] = &apos;ATSDR Acute MRL&apos; THEN [ATSDR MRL - Inhalation, Acute (µg/m³) (copy)_1660983859081338898]&#13;&#10;ELSEIF [Parameters].[Tier 1 Screening (copy)_1660983859054985224] = &apos;ATSDR Intermediate MRL&apos; THEN [ATSDR MRL - Inhalation, Intermediate (µg/m³) (copy)_1660983859081543700]&#13;&#10;ELSEIF [Parameters].[Tier 1 Screening (copy)_1660983859054985224] = &apos;ATSDR Chronic MRL&apos; THEN [ATSDR MRL - Inhalation, Chronic (µg/m³) (copy)_1660983859081486355]&#13;&#10;ELSEIF [Parameters].[Tier 1 Screening (copy)_1660983859054985224] = &apos;None&apos; THEN NULL&#13;&#10;END' />
            </column>
