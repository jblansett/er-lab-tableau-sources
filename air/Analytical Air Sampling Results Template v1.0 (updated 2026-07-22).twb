    <datasource caption='Pump Sampling Results SQL with MRLs' inline='true' name='federated.16cxr940m3r36o0zkokbt001ie37' version='18.1'>
      <connection class='federated'>
        <named-connections>
          <named-connection caption='10.1.30.4' name='postgres.17wd8wn1u8tfi017usxfq1u8kb0o'>
            <connection authentication='username-password' class='postgres' dbname='samples_cteh_com' one-time-sql='' port='5432' server='10.1.30.4' server-oauth='' sslmode='require' username='jblansett' workgroup-auth-mode='prompt' />
