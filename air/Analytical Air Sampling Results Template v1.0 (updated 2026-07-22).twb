            </column>
            <column caption='Tier 3 Screening Value' datatype='real' name='[Tier 2 Screening Value (copy)_1660983859055599629]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='IF [Parameters].[Tier 1 Screening (copy) (copy)_1660983859054993417] = &apos;ATSDR Acute MRL&apos; THEN [ATSDR MRL - Inhalation, Acute (ppbv) (copy)_1660983859048562689]&#13;&#10;ELSEIF [Parameters].[Tier 1 Screening (copy) (copy)_1660983859054993417] = &apos;ATSDR Intermediate MRL&apos; THEN [ATSDR MRL - Inhalation, Intermediate (ppbv) (copy)_1660983859048689667]&#13;&#10;ELSEIF [Parameters].[Tier 1 Screening (copy) (copy)_1660983859054993417] = &apos;ATSDR Chronic MRL&apos; THEN [ATSDR MRL - Inhalation, Chronic (ppbv) (copy)_1660983859048624130]&#13;&#10;ELSEIF [Parameters].[Tier 1 Screening (copy) (copy)_1660983859054993417] = &apos;None&apos; THEN NULL&#13;&#10;END' />
