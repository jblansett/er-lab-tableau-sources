            <column caption='Detection Legend' datatype='string' name='[Calculation_1660983859081854997]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='IF [Detected?] THEN &apos;Detection&apos; ELSE &apos;Non-Detection&apos; END' />
            </column>
            <column caption='Location Geometry' datatype='spatial' name='[Calculation_1660983859093446691]' role='measure' type='nominal'>
              <calculation class='tableau' formula='MAKEPOINT([Location Latitude], [Location Longitude], 4326) &#13;&#10;&#13;&#10;//SRID 4326 = Coord System WGS1984&#13;&#10;//Best geographic coord system for point data' />
            </column>
            <column caption='Count of Samples' datatype='integer' name='[Calculation_2221584830484494]' role='measure' type='ordinal'>
              <calculation class='tableau' formula='COUNTD([Sample ID])' />
            </column>
            <column caption='Project Geometry' datatype='spatial' name='[Calculation_804455509491052545]' role='measure' type='nominal'>
