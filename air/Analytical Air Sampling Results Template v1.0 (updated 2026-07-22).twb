            <column caption='Tier 1 Screening Value' datatype='real' name='[Calculation_1660983859082088470]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='IF [Parameters].[Parameter 1] = &apos;ATSDR Acute MRL&apos; THEN [ATSDR MRL - Inhalation, Acute (µg/m³) (copy)_1660983859081338898]&#13;&#10;ELSEIF [Parameters].[Parameter 1] = &apos;ATSDR Intermediate MRL&apos; THEN [ATSDR MRL - Inhalation, Intermediate (µg/m³) (copy)_1660983859081543700]&#13;&#10;ELSEIF [Parameters].[Parameter 1] = &apos;ATSDR Chronic MRL&apos; THEN [ATSDR MRL - Inhalation, Chronic (µg/m³) (copy)_1660983859081486355]&#13;&#10;ELSEIF [Parameters].[Parameter 1] = &apos;None&apos; THEN NULL&#13;&#10;END' />
            </column>
            <column caption='Screening Value' datatype='string' name='[Calculation_1660983859082391577]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='IF NOT ISNULL([Calculation_1660983859082088470]) THEN&#13;&#10;    CASE [Parameters].[Parameter 1]&#13;&#10;        WHEN &quot;ATSDR Acute MRL&quot; THEN [ATSDR MRL - Inhalation, Acute (µg/m³) String] + &quot; (Acute)&quot;&#13;&#10;        WHEN &quot;ATSDR Intermediate MRL&quot; THEN [ATSDR MRL - Inhalation, Intermediate (µg/m³) String] + &quot; (Int)&quot;&#13;&#10;        WHEN &quot;ATSDR Chronic MRL&quot; THEN [ATSDR MRL - Inhalation, Chronic (µg/m³) String] + &quot; (Chronic)&quot;&#13;&#10;    END&#13;&#10;&#13;&#10;ELSEIF NOT ISNULL([Tier 1 Screening Value (copy)_1660983859082207255]) THEN&#13;&#10;    CASE [Parameters].[Tier 1 Screening (copy)_1660983859054985224]&#13;&#10;        WHEN &quot;ATSDR Acute MRL&quot; THEN [ATSDR MRL - Inhalation, Acute (µg/m³) String] + &quot; (Acute)&quot;&#13;&#10;        WHEN &quot;ATSDR Intermediate MRL&quot; THEN [ATSDR MRL - Inhalation, Intermediate (µg/m³) String] + &quot; (Int)&quot;&#13;&#10;        WHEN &quot;ATSDR Chronic MRL&quot; THEN [ATSDR MRL - Inhalation, Chronic (µg/m³) String] + &quot; (Chronic)&quot;&#13;&#10;    END&#13;&#10;&#13;&#10;ELSEIF NOT ISNULL([Tier 1 Screening Value (copy) (copy)_1660983859082211352]) THEN&#13;&#10;    CASE [Parameters].[Tier 1 Screening (copy) (copy)_1660983859054993417]&#13;&#10;        WHEN &quot;ATSDR Acute MRL&quot; THEN [ATSDR MRL - Inhalation, Acute (µg/m³) String] + &quot; (Acute)&quot;&#13;&#10;        WHEN &quot;ATSDR Intermediate MRL&quot; THEN [ATSDR MRL - Inhalation, Intermediate (µg/m³) String] + &quot; (Int)&quot;&#13;&#10;        WHEN &quot;ATSDR Chronic MRL&quot; THEN [ATSDR MRL - Inhalation, Chronic (µg/m³) String] + &quot; (Chronic)&quot;&#13;&#10;    END&#13;&#10;&#13;&#10;ELSE&#13;&#10;    &quot;NE&quot;&#13;&#10;END' />
            </column>
            <column caption='Screening Legend' datatype='string' name='[Calculation_1660983859082719258]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='IF NOT [Detected?] THEN&#13;&#10;    &quot;Non-Detection&quot;&#13;&#10;&#13;&#10;ELSEIF ISNULL([Calculation_1660983859082088470])&#13;&#10;    AND ISNULL([Tier 1 Screening Value (copy)_1660983859082207255])&#13;&#10;    AND ISNULL([Tier 1 Screening Value (copy) (copy)_1660983859082211352])&#13;&#10;THEN&#13;&#10;    &quot;Detection - No Screening Value Established&quot;&#13;&#10;&#13;&#10;ELSEIF NOT ISNULL([Calculation_1660983859082088470]) THEN&#13;&#10;    IF [Result] &gt;= [Calculation_1660983859082088470] THEN&#13;&#10;        &quot;Detection ≥ Screening Value&quot;&#13;&#10;    ELSE&#13;&#10;        &quot;Detection &lt; Screening Value&quot;&#13;&#10;    END&#13;&#10;&#13;&#10;ELSEIF NOT ISNULL([Tier 1 Screening Value (copy)_1660983859082207255]) THEN&#13;&#10;    IF [Result] &gt;= [Tier 1 Screening Value (copy)_1660983859082207255] THEN&#13;&#10;        &quot;Detection ≥ Screening Value&quot;&#13;&#10;    ELSE&#13;&#10;        &quot;Detection &lt; Screening Value&quot;&#13;&#10;    END&#13;&#10;&#13;&#10;ELSEIF NOT ISNULL([Tier 1 Screening Value (copy) (copy)_1660983859082211352]) THEN&#13;&#10;    IF [Result] &gt;= [Tier 1 Screening Value (copy) (copy)_1660983859082211352] THEN&#13;&#10;        &quot;Detection ≥ Screening Value&quot;&#13;&#10;    ELSE&#13;&#10;        &quot;Detection &lt; Screening Value&quot;&#13;&#10;    END&#13;&#10;&#13;&#10;ELSE&#13;&#10;    &quot;Detection - No Screening Value Established&quot;&#13;&#10;END' />
            </column>
