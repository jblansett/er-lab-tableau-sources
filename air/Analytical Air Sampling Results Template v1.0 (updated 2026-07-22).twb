    <worksheet name='TO-15 Explorer'>
      <layout-options export-legend-location='bottom' export-margin-bottom='0.25' export-margin-left='0.25' export-margin-right='0.25' export-margin-top='0.25'>
        <title>
          <formatted-text>
            <run fontcolor='#555555' fontname='Arial'><![CDATA[<[federated.1gw41mf0rtc9dw1glafc4167k6u4].[none:Project Name:nk]>]]></run>
            <run>Æ&#10;</run>
            <run fontname='Arial Black' fontsize='12'><![CDATA[<[Parameters].[Parameter 2]> | <[federated.1gw41mf0rtc9dw1glafc4167k6u4].[none:Project City:nk]>, <[federated.1gw41mf0rtc9dw1glafc4167k6u4].[none:Project State:nk]>]]></run>
            <run>Æ&#10;</run>
            <run fontname='Arial Black' fontsize='12'>&lt;Sheet Name&gt;</run>
          </formatted-text>
        </title>
        <caption>
          <formatted-text>
            <run><![CDATA[Target analytes that were not detected are reported as the "<" symbol followed by the reporting limit]]></run>
          </formatted-text>
        </caption>
      </layout-options>
      <repository-location id='TO-15Explorer' path='/workbooks/PROJ-069775AnalyticalAirReporting' revision='' />
      <table>
        <view>
          <datasources>
            <datasource caption='Minican Sampling Results SQL with MRLs' name='federated.1gw41mf0rtc9dw1glafc4167k6u4' />
          </datasources>
          <datasource-dependencies datasource='Parameters'>
            <column caption='Enter Project Number' datatype='string' name='[Parameter 2]' param-domain-type='any' role='measure' type='nominal' value='&quot;PROJ-069775&quot;'>
              <calculation class='tableau' formula='&quot;PROJ-069775&quot;' />
            </column>
          </datasource-dependencies>
          <datasource-dependencies datasource='federated.1gw41mf0rtc9dw1glafc4167k6u4'>
            <column datatype='string' name='[Analyte]' role='dimension' type='nominal' />
            <column datatype='string' name='[Analytical Method]' role='dimension' type='nominal' />
            <column datatype='string' name='[CAS Number]' role='dimension' type='nominal' />
            <column caption='Detection Legend' datatype='string' name='[Calculation_1660983859049345028]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='IF [Detected?] THEN &apos;Detection&apos; ELSE &apos;Non-Detection&apos; END' />
            </column>
            <column caption='Detection Range' datatype='string' name='[Calculation_2221584817442816]' role='measure' type='nominal'>
              <calculation class='tableau' formula='IF [Calculation_2221584820383755] = 0 THEN&#13;&#10;    MIN([Calculation_2221584820035593])&#13;&#10;ELSEIF [Calculation_2221584820383755] = 1 THEN&#13;&#10;    MIN([Calculation_2221584819933192])&#13;&#10;ELSE&#13;&#10;    MIN([Calculation_2221584819933192]) + &apos; - &apos; + MAX([Calculation_2221584820232202])&#13;&#10;END' />
            </column>
            <column caption='Count of Samples' datatype='integer' name='[Calculation_2221584818126849]' role='measure' type='ordinal'>
              <calculation class='tableau' formula='COUNTD([Sample ID])' />
            </column>
            <column caption='_Min Detection Value' datatype='real' name='[Calculation_2221584819023877]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='{ INCLUDE [Analyte], [CAS Number], [Result Units] :&#13;&#10;    MIN(IF [Detected?] THEN [Result] END) }' />
            </column>
            <column caption='_Max Detection Value' datatype='real' name='[Calculation_2221584819585030]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='{ INCLUDE [Analyte], [CAS Number], [Result Units] :&#13;&#10;    MAX(IF [Detected?] THEN [Result] END) }' />
            </column>
            <column caption='_Min All Value' datatype='real' name='[Calculation_2221584819654663]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='{ INCLUDE [Analyte], [CAS Number], [Result Units] :&#13;&#10;    MIN([Result]) }' />
            </column>
            <column caption='_Min Detect Formatted' datatype='string' name='[Calculation_2221584819933192]' role='measure' type='nominal'>
              <calculation class='tableau' formula='{ INCLUDE [Analyte], [CAS Number], [Result Units] :&#13;&#10;    MIN(IF [Detected?] AND [Result] = [Calculation_2221584819023877]&#13;&#10;        THEN [Result Formatted] END) }' />
            </column>
            <column caption='_Min All Formatted' datatype='string' default-type='ordinal' name='[Calculation_2221584820035593]' role='measure' type='nominal'>
              <calculation class='tableau' formula='{ INCLUDE [Analyte], [CAS Number], [Result Units] :&#13;&#10;    MIN(IF [Result] = [Calculation_2221584819654663]&#13;&#10;        THEN [Result Formatted] END) }' />
            </column>
            <column caption='_Max Detect Formatted' datatype='string' name='[Calculation_2221584820232202]' role='measure' type='nominal'>
              <calculation class='tableau' formula='{ INCLUDE [Analyte], [CAS Number], [Result Units] :&#13;&#10;    MAX(IF [Detected?] AND [Result] = [Calculation_2221584819585030]&#13;&#10;        THEN [Result Formatted] END) }' />
            </column>
