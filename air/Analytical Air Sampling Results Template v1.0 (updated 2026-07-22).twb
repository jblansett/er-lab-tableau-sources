      <datasource-dependencies datasource='Parameters'>
        <column caption='Tier 1 Screening' datatype='string' name='[Parameter 1]' param-domain-type='list' role='measure' type='nominal' value='&quot;ATSDR Chronic MRL&quot;'>
          <calculation class='tableau' formula='&quot;ATSDR Chronic MRL&quot;' />
        </column>
        <column caption='Enter Project Number' datatype='string' name='[Parameter 2]' param-domain-type='any' role='measure' type='nominal' value='&quot;PROJ-069775&quot;'>
          <calculation class='tableau' formula='&quot;PROJ-069775&quot;' />
        </column>
        <column caption='Tier 3 Screening' datatype='string' name='[Tier 1 Screening (copy) (copy)_1660983859054993417]' param-domain-type='list' role='measure' type='nominal' value='&quot;ATSDR Acute MRL&quot;'>
          <calculation class='tableau' formula='&quot;ATSDR Acute MRL&quot;' />
        </column>
        <column caption='Tier 2 Screening' datatype='string' name='[Tier 1 Screening (copy)_1660983859054985224]' param-domain-type='list' role='measure' type='nominal' value='&quot;ATSDR Intermediate MRL&quot;'>
